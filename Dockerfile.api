FROM rust:1.78-slim as builder
WORKDIR /app
COPY . .
RUN cargo build --release -p astra-research-api

FROM debian:bookworm-slim
WORKDIR /app
COPY --from=builder /app/target/release/astra-research-api .
COPY --from=builder /app/research/ ./research/
COPY --from=builder /app/datasets/ ./datasets/
EXPOSE 8090
CMD ["./astra-research-api"]
